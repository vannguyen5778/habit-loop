generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Habit {
  id             String   @id
  deviceId       String
  name           String
  description    String?
  frequency      String   @default("daily")
  completedDates String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isArchived     Boolean  @default(false)

  @@index([deviceId])
}
